generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SubmissionStatus {
  SUBMITTED
  RECEIVED
  VERIFIED
  SORTED
  SENT
  COMPLETED
}

model School {
  id            Int            @id @default(autoincrement())
  code          String         @unique
  name          String         @unique
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  booths        Booth[]
  counterScopes CounterScope[]
  submissions   Submission[]

  @@map("schools")
}

model Booth {
  id          Int          @id @default(autoincrement())
  schoolId    Int          @map("school_id")
  name        String
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@unique([schoolId, name])
  @@index([schoolId, isActive])
  @@map("booths")
}

model LetterType {
  id            Int            @id @default(autoincrement())
  code          String         @unique
  name          String         @unique
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  counterScopes CounterScope[]
  submissions   Submission[]

  @@map("letter_types")
}

model CounterScope {
  id           Int        @id @default(autoincrement())
  schoolId     Int        @map("school_id")
  letterTypeId Int        @map("letter_type_id")
  currentValue Int        @default(0) @map("current_value")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  letterType   LetterType @relation(fields: [letterTypeId], references: [id], onDelete: Cascade)

  @@unique([schoolId, letterTypeId])
  @@map("counter_scopes")
}

model Submission {
  id                   Int              @id @default(autoincrement())
  schoolId             Int              @map("school_id")
  boothId              Int              @map("booth_id")
  letterTypeId         Int              @map("letter_type_id")
  senderName           String           @map("sender_name")
  studentId            String           @map("student_id")
  phone                String
  senderAddress        String?          @map("sender_address")
  college              String? 
  grade                String?
  recipientName        String?          @map("recipient_name")
  recipientPhone       String?          @map("recipient_phone")
  recipientAddress     String?          @map("recipient_address")
  recipientSchoolGrade String?          @map("recipient_school_grade")
  recipientRemark      String?          @map("recipient_remark")
  freeLetterTopic      String?          @map("free_letter_topic")
  displayCode          String           @unique @map("display_code")
  rawCode              String           @unique @map("raw_code")
  status               SubmissionStatus @default(SUBMITTED)
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  school               School           @relation(fields: [schoolId], references: [id])
  booth                Booth            @relation(fields: [boothId], references: [id])
  letterType           LetterType       @relation(fields: [letterTypeId], references: [id])

  @@index([schoolId, boothId])
  @@index([schoolId, letterTypeId, status])
  @@index([studentId])
  @@index([phone])
  @@index([senderName])
  @@index([createdAt])
  @@map("submissions")
}
